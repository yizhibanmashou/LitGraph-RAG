# Copy this file to .env.local and fill in local values.
# Server-side LLM proxy. Do not expose provider keys through VITE_* variables.
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com

# Optional: force the frontend to use static explanations only.
VITE_LLM_STATIC_ONLY=false

# Optional OCR pipeline token.
PADDLEOCR_AISTUDIO_TOKEN=
